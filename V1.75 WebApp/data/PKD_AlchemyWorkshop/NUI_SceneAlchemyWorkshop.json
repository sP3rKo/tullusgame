{
    "type": "screen",
    "constants": {
        "craftSuccessSound": "Item3"
    },
    "animations": [
        {
            "field": "opacity",
            "func": "linear",
            "repeats": 0,
            "duration": 0.25,
            "relative": false,
            "delay": 0,
            "keyframes": {
                "0": 0,
                "30": 0,
                "100": 255
            }
        }
    ],
    "childrens": [
        {
            "type": "image",
            "id": "_backgroundImage",
            "parameters": {
                "imageName": "background",
                "folderName": "PKD_AlchemyWorkshop",
                "keepAspect": false,
                "useAspectSize": false
            },
            "bindings": {
                "size": {
                    "width": "688hdp",
                    "height": "620hdp"
                },
                "position": {
                    "x": "center",
                    "y": "center"
                }
            },
            "childrens": [
                {
                    "type": "group",
                    "id": "_mainGroup",
                    "parameters": {
                        "keyboardHandling": true,
                        "horizontalNavigation": false,
                        "freeNavigation": false
                    },
                    "bindings": {
                        "size": {
                            "width": "440hdp",
                            "height": "560hdp"
                        },
                        "position": {
                            "x": "center",
                            "y": "center"
                        }
                    },
                    "childrens": [
                        {
                            "type": "imageButton",
                            "id": "_baseItemButton",
                            "parameters": {
                                "imageName": "back_rmb",
                                "folderName": "PKD_AlchemyWorkshop",
                                "hoverImageName": "back_rmb_hover",
                                "pressedImageName": "",
                                "disabledImageName": "",
                                "isCheckAlpha": false,
                                "clickSe": "Cursor1",
                                "desaturateWhenDisabled": false,
                                "tint": "",
                                "tintAlpha": 0.5,     
                                "overTint": "",
                                "overTintAlpha": 0.5,
                                "activeTint": "",
                                "activeTintAlpha": 0.5,
                                "disabledTint": "",
                                "disabledTintAlpha": 0.5,
                                "keyboardKey": "",
                                "keyboardHandled": true,
                                "enabled": true
                            },
                            "bindings": {
                                "size": {
                                    "width": "140hdp",
                                    "height": "140hdp"
                                },
                                "position": {
                                    "x": "center",
                                    "y": 0
                                }
                            },
                            "childrens": [
                                {
                                    "type": "image",
                                    "id": "_baseItemIconImage",
                                    "parameters": {
                                        "folderName": "PKD_AlchemyWorkshop",
                                        "keepAspect": true,
                                        "useAspectSize": true
                                    },
                                    "bindings": {
                                        "size": {
                                            "width": "38%",
                                            "height": "38%"
                                        },
                                        "position": {
                                            "x": "center",
                                            "y": "center"
                                        },
                                        "image": "$baseItemIcon"
                                    }
                                },
                                {
                                    "type": "plane",
                                    "parameters": {
                                        "margins": 64,
                                        "imageName": "frame_rmb",
                                        "folderName": "PKD_AlchemyWorkshop"
                                    },
                                    "bindings": {
                                        "size": {
                                            "width": "100%",
                                            "height": "100%"
                                        },
                                        "position": {
                                            "x": "center",
                                            "y": "center"
                                        }
                                    }
                                }
                            ]
                        },
                        {
                            "type": "imageButton",
                            "id": "_materialsButton",
                            "parameters": {
                                "imageName": "back_square_long",
                                "folderName": "PKD_AlchemyWorkshop",
                                "hoverImageName": "back_square_long_hover",
                                "pressedImageName": "",
                                "disabledImageName": "",
                                "isCheckAlpha": false,
                                "clickSe": "Cursor1",
                                "desaturateWhenDisabled": false,
                                "tint": "",
                                "tintAlpha": 0.5,     
                                "overTint": "",
                                "overTintAlpha": 0.5,
                                "activeTint": "",
                                "activeTintAlpha": 0.5,
                                "disabledTint": "",
                                "disabledTintAlpha": 0.5,
                                "keyboardKey": "",
                                "keyboardHandled": true,
                                "enabled": true
                            },
                            "bindings": {
                                "size": {
                                    "width": "100%",
                                    "height": "120hdp"
                                },
                                "position": {
                                    "x": "center",
                                    "y": "prevEndY + 16hdp"
                                }
                            },
                            "childrens": [
                                {
                                    "type": "group",
                                    "id": "_materialsGroup",
                                    "bindings": {
                                        "size": {
                                            "width": "auto",
                                            "height": "100%"
                                        },
                                        "position": {
                                            "x": "center",
                                            "y": "center"
                                        }
                                    }
                                },
                                {
                                    "type": "plane",
                                    "parameters": {
                                        "margins": 26,
                                        "imageName": "frame_square",
                                        "folderName": "PKD_AlchemyWorkshop"
                                    },
                                    "bindings": {
                                        "size": {
                                            "width": "100%",
                                            "height": "100%"
                                        },
                                        "position": {
                                            "x": "center",
                                            "y": "center"
                                        }
                                    }
                                }
                            ]
                        },
                        {
                            "type": "group",
                            "id": "_resultsSection",
                            "bindings": {
                                "size": {
                                    "width": "380hdp",
                                    "height": "140hdp"
                                },
                                "position": {
                                    "x": "center",
                                    "y": "prevEndY + 16hdp"
                                }
                            }
                        },
                        {
                            "type": "imageButton",
                            "id": "_craftButton",
                            "parameters": {
                                "imageName": "button_long",
                                "folderName": "PKD_AlchemyWorkshop",
                                "hoverImageName": "button_long_hover",
                                "isPlane": true,
                                "margins": 14,
                                "pressedImageName": "",
                                "disabledImageName": "button_long_disabled",
                                "isCheckAlpha": false,
                                "clickSe": "Cursor1",
                                "desaturateWhenDisabled": false,
                                "tint": "",
                                "tintAlpha": 0.5,     
                                "overTint": "",
                                "overTintAlpha": 0.5,
                                "activeTint": "",
                                "activeTintAlpha": 0.5,
                                "disabledTint": "",
                                "disabledTintAlpha": 0.5,
                                "keyboardKey": "",
                                "keyboardHandled": true,
                                "enabled": true
                            },
                            "bindings": {
                                "size": {
                                    "width": "200hdp",
                                    "height": "50hdp"
                                },
                                "position": {
                                    "x": "center",
                                    "y": "prevEndY + 34hdp"
                                },
                                "enable": "$isCraftButtonEnabled"
                            },
                            "childrens": [
                                {
                                    "type": "text",
                                    "id": "_craftButtonTitle",
                                    "parameters": {
                                        "alignment": "center",
                                        "font": {
                                            "face": null,
                                            "size": 18,
                                            "italic": false,
                                            "bold": false,
                                            "weight": 0
                                        },
                                        "margins": { "x": 0, "y": 0 },
                                        "outline": { "color": "#000000", "width": 2 },
                                        "textColor": "#FFFFFF",
                                        "shadow": {
                                            "color": "#000",
                                            "opacity": 0,
                                            "margins": { "x": 1, "y": 1 }
                                        },
                                        "text": "CREATE",
                                        "multiline": false,
                                        "verticalCentered": true,
                                        "actualWidth": false,
                                        "actualHeight": false,
                                        "isLoadFontFromFile": false
                                    },
                                    "bindings": {
                                        "size": {
                                            "width": "90%",
                                            "height": "96%"
                                        },
                                        "position": {
                                            "x": "center",
                                            "y": "center"
                                        },
                                        "textColor": "$isCraftButtonEnabled ? #FFFFFF : #8d8175"
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "type": "imageButton",
            "id": "_closeButton",
            "parameters": {
                "imageName": "close_button_0",
                "folderName": "PKD_AlchemyWorkshop",
                "hoverImageName": "close_button_1",
                "pressedImageName": "close_button_0",
                "disabledImageName": "",

                "isCheckAlpha": false,

                "clickSe": "Cursor1",

                "desaturateWhenDisabled": false,

                "tint": "",
                "tintAlpha": 0.5,
                
                "overTint": "",
                "overTintAlpha": 0.5,

                "activeTint": "",
                "activeTintAlpha": 0.5,

                "disabledTint": "",
                "disabledTintAlpha": 0.5,

                "keyboardKey": "cancel",
                "keyboardHandled": true,
                "enabled": true
            },
            "bindings": {
                "size": {
                    "width": "52hdp",
                    "height": "52hdp"
                },
                "position": {
                    "x": "right - 4hdp",
                    "y": "4hdp"
                }
            }
        }
    ]
}