{
    "type": "rect",
    "id": "_backFrame",
    "parameters": {
        "corners": 8,
        "fillColor": "#1a1102",
        "fillAlpha": 0.8,
        "strokeWidth": 2,
        "strokeColor": "#8d8175",
        "strokeAlpha": 1
    },
    "bindings": {
        "size": {
            "width": "380hdp",
            "height": "150hdp"
        }
    },
    "childrens": [
        {
            "type": "textPro",
            "id": "_resultItemNameSprite",
            "parameters": {
                "alignment": "center",
                "font": {
                    "face": null,
                    "size": 18,
                    "italic": false,
                    "bold": false,
                    "weight": 0
                },
                "margins": { "x": 0, "y": 0 },
                "outline": { "color": "#000000", "width": 2 },
                "shadow": {
                    "color": "#000",
                    "opacity": 0,
                    "margins": { "x": 1, "y": 1 }
                },
                "multiline": false,
                "verticalCentered": true,
                "actualWidth": false,
                "actualHeight": false,
                "isLoadFontFromFile": false
            },
            "bindings": {
                "size": {
                    "width": "98%",
                    "height": "22hdp"
                },
                "position": {
                    "x": "center",
                    "y": "4hdp"
                },
                "textColor": "#f7e22c",
                "fontSize": "20hdp",
                "text": "$resultItemName"
            }
        },
        {
            "type": "image",
            "id": "_itemImage",
            "parameters": {
                "imageName": 64,
                "folderName": "pictures",
                "keepAspect": true,
                "useAspectSize": true
            },
            "bindings": {
                "size": {
                    "width": "56hdp",
                    "height": "56hdp"
                },
                "position": {
                    "x": "8hdp",
                    "y": "center + 10hdp"
                },
                "image": "$itemImage"
            }
        },
        {
            "type": "text",
            "id": "_slotItemDescriptionText",
            "parameters": {
                "alignment": "center",
                "font": {
                    "face": null,
                    "size": 16,
                    "italic": false,
                    "bold": false,
                    "weight": 0
                },
                "margins": { "x": 0, "y": 0 },
                "outline": { "color": null, "width": 2 },
                "textColor": "#FFFFFF",
                "shadow": {
                    "color": "#000",
                    "opacity": 0,
                    "margins": { "x": 1, "y": 1 }
                },
                "text": "",
                "multiline": true,
                "verticalCentered": true,
                "verticalAlignment": "top",
                "verticalSpacing": 4,
                "actualWidth": false,
                "actualHeight": false,
                "trimWidth": false,
                "trimHeight": false,
                "iconPadding": {
                    "left": 2,
                    "right": 2,
                    "top": 0,
                    "bottom": 0
                },
                "iconSize": 1,
                "isStaticIconSize": false,
                "isLoadFontFromFile": false
            },
            "bindings": {
                "size": {
                    "width": "90% - 60hdp",
                    "height": "100% - 28hdp"
                },
                "position": {
                    "x": "prevEndX + 6hdp",
                    "y": "24hdp"
                },
                "text": "$descriptionText",
                "fontSize": "15hdp"
            }
        }
    ]
}