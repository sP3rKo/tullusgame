{
    "type": "screen",
    "constants": {
        "animations": [
            {
                "field": "opacity",
                "duration": 0.5,
                "func": "linear",
                "delay": 0.5,
                "repeats": 0,
                "relative": false,
                "keyframes": {
                    "0": 255,
                    "100": 0
                }
            },
            {
                "field": "y",
                "duration": 1,
                "func": "linear",
                "delay": 0.5,
                "repeats": 0,
                "relative": true,
                "keyframes": {
                    "0": 0,
                    "100": -500
                }
            }
        ]
    },
    "childrens": [
        {
            "type": "rect",
            "id": "_backFrame",
            "parameters": {
                "corners": 18,
                "fillColor": "#2d6539",
                "fillAlpha": 0.9,
                "strokeWidth": 2,
                "strokeColor": "#0fc972",
                "strokeAlpha": 1
            },
            "bindings": {
                "size": {
                    "width": "360hdp",
                    "height": "90hdp"
                },
                "position": {
                    "x": "center",
                    "y": "center"
                }
            },
            "childrens": [
                {
                    "type": "text",
                    "id": "_successText",
                    "parameters": {
                        "alignment": "center",
                        "font": {
                            "face": null,
                            "size": 16,
                            "italic": false,
                            "bold": false,
                            "weight": 0
                        },
                        "margins": { "x": 0, "y": 0 },
                        "outline": { "color": "#000000", "width": 1 },
                        "textColor": "#cad61d",
                        "shadow": {
                            "color": "#000",
                            "opacity": 250,
                            "margins": { "x": 2, "y": 2 }
                        },
                        "text": "",
                        "multiline": true,
                        "verticalCentered": true,
                        "actualWidth": false,
                        "actualHeight": false,
                        "isLoadFontFromFile": false
                    },
                    "bindings": {
                        "size": {
                            "width": "90%",
                            "height": "90%"
                        },
                        "position": {
                            "x": "center",
                            "y": "center"
                        },
                        "text": "You created a new item!",
                        "fontSize": "26hdp"
                    }
                }
            ]
        }
    ]
}