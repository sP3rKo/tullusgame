{
    "type": "group",
    "id": "_itemMain",
    "constants": {
        "clearText": "[REMOVE]"
    },
    "bindings": {
        "size": {
            "width": "68hdp",
            "height": "68hdp"
        }
    },
    "childrens": [
        {
            "type": "group",
            "parameters": {},
            "bindings": {
                "size": {
                    "width": "94%",
                    "height": "94%"
                },
                "position": {
                    "x": "center",
                    "y": "center"
                }
            },
            "childrens": [
                {
                    "type": "group",
                    "id": "_itemContentGroup",
                    "childrens": [
                        {
                            "type": "image",
                            "id": "_itemImage",
                            "createIf": "$isHaveItem",
                            "parameters": {
                                "folderName": "pictures",
                                "keepAspect": false,
                                "useAspectSize": false
                            },
                            "bindings": {
                                "size": {
                                    "width": "88%",
                                    "height": "88%"
                                },
                                "position": {
                                    "x": "center",
                                    "y": "center"
                                },
                                "image": "$itemImage"
                            }
                        },
                        {
                            "type": "image",
                            "id": "_emptyItemImage",
                            "createIf": "$isEmptyItem",
                            "parameters": {
                                "folderName": "PKD_AlchemyWorkshop",
                                "imageName": "clear",
                                "keepAspect": false,
                                "useAspectSize": false
                            },
                            "bindings": {
                                "size": {
                                    "width": "62%",
                                    "height": "62%"
                                },
                                "position": {
                                    "x": "center",
                                    "y": "center"
                                }
                            }
                        },
                        {
                            "type": "text",
                            "parameters": {
                                "alignment": "right",
                                "font": {
                                    "face": null,
                                    "size": 18,
                                    "italic": false,
                                    "bold": false,
                                    "weight": 0
                                },
                                "margins": { "x": 0, "y": 0 },
                                "outline": { "color": "#000000", "width": 2 },
                                "textColor": "#FFFFFF",
                                "shadow": {
                                    "color": "#000",
                                    "opacity": 220,
                                    "margins": { "x": 1, "y": 0.5 }
                                },
                                "multiline": false,
                                "verticalCentered": true,
                                "actualWidth": false,
                                "actualHeight": false,
                                "isLoadFontFromFile": false
                            },
                            "bindings": {
                                "size": {
                                    "width": "92%",
                                    "height": "20hdp"
                                },
                                "position": {
                                    "x": "right - 4hdp",
                                    "y": "bottom - 2hdp"
                                },
                                "fontSize": "18hdp",
                                "text": "$itemAmountText"
                            }
                        }
                    ],
                    "bindings": {
                        "size": {
                            "width": "92%",
                            "height": "92%"
                        },
                        "position": {
                            "x": "center",
                            "y": "center"
                        },
                        "centeredScale": 1
                    }
                },
                {
                    "type": "plane",
                    "id": "_selectedImage",
                    "parameters": {
                        "imageName": "frame_square",
                        "margins": 14,
                        "folderName": "PKD_AlchemyWorkshop"
                    },
                    "bindings": {
                        "size": {
                            "width": "100%",
                            "height": "100%"
                        },
                        "position": {
                            "x": "center",
                            "y": "center"
                        },
                        "visible": "$isSelected"
                    }
                }
            ]
        }
    ]
}