{
    "type": "screen",
    "childrens": [
        {
            "type": "rect",
            "id": "_listBackground",
            "parameters": {
                "corners": 12,
                "fillGradient": null,
                "gradientStart": { "x": 0, "y": 0 },
                "gradientEnd": { "x": 0, "y": 100 },
                "fillColor": "#1a1102",
                "fillAlpha": 0.8,
                "strokeWidth": 2,
                "strokeColor": "#8d8175",
                "strokeAlpha": 1
            },
            "bindings": {
                "width": "500hdp",
                "height": "420hdp",
                "position": {
                    "x": "center",
                    "y": "center - 45hdp"
                }
            },
            "childrens": [
                {
                    "type": "list",
                    "id": "_itemsList",
                    "parameters": {
                        "maxCols": 5,
                        "isHaveSelectionEffect": false,
                        "selectionEffects": ["glow;distance:12;outerStrength:3"],
                        "scaleItemsWidth": false,
                        "scaleItemsHeight": false,
                        "isDrawDefaultItemBack": false,
                        "defaultItemHeight": 0,
                        "backgroundType": 2,
                        "itemsPadding": 6,
                        "isHaveInOutAnimation": false,
                        "isHorizontal": false,
                        "inAnimation": "field:x;duration:0.15;keyframes:0=0,100=4",
                        "outAnimation": "field:x;duration:0.15;keyframes:0=4,100=0",
                        "isPlayOkSound": true,
                        "isPlayCursorSound": true
                    },
                    "bindings": {
                        "width": "100%",
                        "height": "100%",
                        "position": {
                            "x": "14hdp",
                            "y": 0
                        }
                    }
                }
            ]
        },
        {
            "type": "rect",
            "id": "_itemDescriptionBack",
            "parameters": {
                "corners": 12,
                "fillGradient": null,
                "gradientStart": { "x": 0, "y": 0 },
                "gradientEnd": { "x": 0, "y": 100 },
                "fillColor": "#1a1102",
                "fillAlpha": 1,
                "strokeWidth": 2,
                "strokeColor": "#8d8175",
                "strokeAlpha": 1
            },
            "bindings": {
                "size": {
                    "width": "400hdp",
                    "height": "96hdp"
                },
                "position": {
                    "x": "center",
                    "y": "prevEndY + 10hdp"
                }
            },
            "childrens": [
                {
                    "type": "textPro",
                    "id": "_itemNameText",
                    "parameters": {
                        "alignment": "center",
                        "font": {
                            "face": null,
                            "size": 18,
                            "italic": false,
                            "bold": false,
                            "weight": 0
                        },
                        "margins": { "x": 0, "y": 0 },
                        "outline": { "color": "#000000", "width": 2 },
                        "shadow": {
                            "color": "#000",
                            "opacity": 0,
                            "margins": { "x": 1, "y": 1 }
                        },
                        "multiline": false,
                        "verticalCentered": true,
                        "actualWidth": false,
                        "actualHeight": false,
                        "isLoadFontFromFile": false
                    },
                    "bindings": {
                        "size": {
                            "width": "98%",
                            "height": "22hdp"
                        },
                        "position": {
                            "x": "center",
                            "y": "4hdp"
                        },
                        "textColor": "#f7e22c",
                        "fontSize": "20hdp",
                        "text": "$selectedItemName"
                    }
                },
                {
                    "type": "text",
                    "id": "_itemDescriptionText",
                    "parameters": {
                        "alignment": "center",
                        "font": {
                            "face": null,
                            "size": 16,
                            "italic": false,
                            "bold": false,
                            "weight": 0
                        },
                        "margins": { "x": 0, "y": 0 },
                        "outline": { "color": null, "width": 2 },
                        "textColor": "#FFFFFF",
                        "shadow": {
                            "color": "#000",
                            "opacity": 0,
                            "margins": { "x": 1, "y": 1 }
                        },
                        "text": "",
                        "multiline": false,
                        "verticalCentered": true,
                        "verticalAlignment": "top",
                        "verticalSpacing": 4,
                        "actualWidth": false,
                        "actualHeight": false,
                        "trimWidth": false,
                        "trimHeight": false,
                        "iconPadding": {
                            "left": 2,
                            "right": 2,
                            "top": 0,
                            "bottom": 0
                        },
                        "iconSize": 1,
                        "isStaticIconSize": false,
                        "isLoadFontFromFile": false
                    },
                    "bindings": {
                        "size": {
                            "width": "92%",
                            "height": "100% - 24hdp"
                        },
                        "position": {
                            "x": "center",
                            "y": "prevEndY"
                        },
                        "text": "$descriptionText"
                    }
                }
            ]
        }
    ]
}