{
    "type": "group",
    "constants": {
        "slotTypeOptional": "[ ADD MATERIAL ]",
        "slotTypeRequired": "[ SET MATERIAL ]"
    },
    "bindings": {
        "size": {
            "width": "260hdp",
            "height": "78hdp"
        }
    },
    "childrens": [
        {
            "type": "rect",
            "id": "_background",
            "parameters": {
                "corners": 0,
                "fillGradient": null,
                "gradientStart": { "x": 0, "y": 0 },
                "gradientEnd": { "x": 0, "y": 100 },
                "fillColor": "#2c1e05",
                "fillAlpha": 1,
                "strokeWidth": 1,
                "strokeColor": "#8d8175",
                "strokeAlpha": 0.5
            },
            "bindings": {
                "size": {
                    "width": "100%",
                    "height": "100%"
                }
            }
        },
        {
            "type": "text",
            "id": "_slotTypeText",
            "createIf": "$isNotHaveItem",
            "parameters": {
                "alignment": "center",
                "font": {
                    "face": "Tahoma",
                    "size": 18,
                    "italic": false,
                    "bold": false,
                    "weight": 500
                },
                "margins": { "x": 0, "y": 0 },
                "outline": { "color": "#000000", "width": 2 },
                "shadow": {
                    "color": "#000",
                    "opacity": 0,
                    "margins": { "x": 1, "y": 1 }
                },
                "text": "",
                "multiline": false,
                "verticalCentered": true,
                "actualWidth": false,
                "actualHeight": false,
                "isLoadFontFromFile": false
            },
            "bindings": {
                "size": {
                    "width": "90%",
                    "height": "96%"
                },
                "position": {
                    "x": "center",
                    "y": "center"
                },
                "textColor": "$isRequired ? #bf6817 : #89c6dc",
                "fontSize": "$isRequired ? 24hdp : 22hdp",
                "text": "$slotTypeText"
            }
        },
        {
            "type": "group",
            "id": "_content",
            "createIf": "$isHaveItem",
            "childrens": [
                {
                    "type": "image",
                    "id": "_itemImage",
                    "parameters": {
                        "imageName": 64,
                        "folderName": "pictures",
                        "keepAspect": true,
                        "useAspectSize": true
                    },
                    "bindings": {
                        "size": {
                            "width": "56hdp",
                            "height": "56hdp"
                        },
                        "position": {
                            "x": "8hdp",
                            "y": "center"
                        },
                        "image": "$materialImage"
                    }
                },
                {
                    "type": "textPro",
                    "id": "_materialItemName",
                    "parameters": {
                        "alignment": "left",
                        "font": {
                            "face": null,
                            "size": 18,
                            "italic": false,
                            "bold": false,
                            "weight": 0
                        },
                        "margins": { "x": 0, "y": 0 },
                        "outline": { "color": "#000000", "width": 2 },
                        "shadow": {
                            "color": "#000",
                            "opacity": 0,
                            "margins": { "x": 1, "y": 1 }
                        },
                        "multiline": false,
                        "verticalCentered": true,
                        "verticalAlignment": "center",
                        "verticalSpacing": 4,
                        "actualWidth": false,
                        "actualHeight": false,
                        "trimWidth": false,
                        "trimHeight": false,
                        "iconPadding": {
                            "left": 2,
                            "right": 2,
                            "top": 0,
                            "bottom": 0
                        },
                        "iconSize": 1,
                        "isStaticIconSize": false,
                        "isLoadFontFromFile": false
                    },
                    "bindings": {
                        "size": {
                            "width": "98% - prevWidth - 4hdp",
                            "height": "96%"
                        },
                        "position": {
                            "x": "prevEndX + 6hdp",
                            "y": "center"
                        },
                        "fontSize": "20hdp",
                        "text": "$materialName"
                    }
                }
            ],
            "bindings": {
                "size": {
                    "width": "100%",
                    "height": "100%"
                }
            }
        },
        {
            "type": "plane",
            "id": "_selectedFrame",
            "parameters": {
                "margins": 26,
                "imageName": "frame_square",
                "folderName": "PKD_AlchemyWorkshop"
            },
            "bindings": {
                "size": {
                    "width": "120%",
                    "height": "106%"
                },
                "position": {
                    "x": "center",
                    "y": "center"
                },
                "visible": "$isSelected"
            }
        }
    ]
}