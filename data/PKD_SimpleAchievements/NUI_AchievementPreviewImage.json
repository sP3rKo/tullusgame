{
    "type": "screen",
    "childrens": [
        {
            "type": "group",
            "id": "_groupElement",
            "constants": {
                "stayTimeInSeconds": 3
            },
            "animations": [
                {
                    "field": "opacity",
                    "duration": 0.2,
                    "func": "linear",
                    "delay": 0.1,
                    "repeats": 0,
                    "relative": false,
                    "keyframes": {
                        "0": 0,
                        "100": 255
                    }
                }
            ],
            "parameters": {
                "keyboardHandling": false,
                "horizontalNavigation": false,
                "freeNavigation": false
            },
            "bindings": {
                "size": {
                    "width": "auto",
                    "height": "auto"
                },
                "x": "$positionX",
                "y": "$positionY"
            },
            "childrens": [
                {
                    "type": "image",
                    "id": "_achievementImage",
                    "parameters": {
                        "folderName": "PKD_SimpleAchievements",
                        "keepAspect": false,
                        "useAspectSize": false
                    },
                    "bindings": {
                        "size": {
                            "width": 64,
                            "height": 64
                        },
                        "position": {
                            "x": "center",
                            "y": 0
                        },
                        "image": "$achievementImage"
                    },
                    "childrens": [
                        {
                            "type": "plane",
                            "id": "_iconFrame",
                            "parameters": {
                                "imageName": "icon_frame",
                                "folderName": "PKD_SimpleAchievements",
                                "margins": 15
                            },
                            "bindings": {
                                "size": {
                                    "width": "115%",
                                    "height": "115%"
                                },
                                "position": {
                                    "x": "center",
                                    "y": "center"
                                }
                            },
                            "childrens": []
                        }
                    ]
                },
                {
                        "type": "text",
                        "id": "_nameTextElement",
                        "effects": ["shadow"],
                        "parameters": {
                            "alignment": "center",
                            "font": {
                                "face": null,
                                "size": 18,
                                "italic": false,
                                "bold": false,
                                "weight": 0
                            },
                            "margins": {
                                "x": 0,
                                "y": 0
                            },
                            "outline": {
                                "color": "#000000",
                                "width": 0
                            },
                            "textColor": "#3e8b9b",
                            "shadow": {
                                "color": "#000",
                                "opacity": 200,
                                "margins": {
                                    "x": 1,
                                    "y": 1
                                }
                            },
                            "multiline": false,
                            "verticalCentered": true,
                            "actualWidth": false,
                            "actualHeight": false,
                            "isLoadFontFromFile": false
                        },
                        "bindings": {
                            "size": {
                                "width": "128hdp",
                                "height": "16hdp"
                            },
                            "position": {
                                "x": "center",
                                "y": "prevEndY + 6hdp"
                            },
                            "fontSize": "15hdp",
                            "text": ["%1", "$achievementName"]
                        },
                        "childrens": []
                    }
            ]
        }
    ]
}